{
  "name": "gordy-elliott-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "brain:prepare": "node scripts/prepare-shift-brain.mjs",
    "brain:ingest": "node scripts/ingest-shift-brain.mjs",
    "check:shift-ai-inputs": "node scripts/check-shift-ai-inputs.mjs",
    "test:terra": "tsx --test tests/terra-contracts.test.ts",
    "test:composio": "tsx --test tests/composio-calendar.test.ts tests/composio-calendar-migration.test.ts",
    "test:native-push": "tsx --test tests/native-push.test.ts",
    "test:release-contracts": "tsx --test tests/native-push.test.ts tests/safe-redirect.test.ts tests/client-experience.test.ts tests/client-attention.test.ts tests/capacity-baseline.test.ts tests/founder-dashboard.test.ts tests/at-capacity-migration.test.ts",
    "verify:app-store-release": "node scripts/verify-app-store-release.mjs",
    "capture:app-store": "node scripts/capture-app-store-screenshots.mjs",
    "verify:mobile": "node scripts/verify-mobile-portal.mjs",
    "verify:app-store-metadata": "node scripts/check-app-store-metadata.mjs",
    "verify:review-fixture": "node scripts/check-app-review-fixture.mjs",
    "verify:portal": "npm run lint && npm run build && npm run check:shift-ai-inputs",
    "ios:prepare": "node scripts/prepare-native-shell.mjs",
    "ios:sync": "CAPACITOR_SERVER_URL=${CAPACITOR_SERVER_URL:-https://gordy-elliott-site.vercel.app} sh -c 'npm run ios:prepare && cap sync ios'",
    "ios:open": "cap open ios",
    "ios:build": "npm run ios:sync && xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -destination 'generic/platform=iOS Simulator' -derivedDataPath ${IOS_DERIVED_DATA_PATH:-.ios-derived-data} CODE_SIGNING_ALLOWED=NO build",
    "ios:preflight": "node scripts/ios-release-preflight.mjs",
    "ios:archive": "npm run ios:sync && npm run ios:preflight && node scripts/archive-ios.mjs",
    "ios:upload": "npm run ios:preflight && node scripts/upload-ios.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@composio/core": "^0.14.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "next": "16.2.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "resend": "6.14.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "ws": "8.21.0",
    "postcss": "8.5.16",
    "sharp": "0.35.3"
  }
}
